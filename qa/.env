# Copy to .env and fill in.

# The deployed Coachify site to test. Override if you're testing a staging URL.
COACHIFY_URL=https://coachify-app.com

# Test accounts created by seed-test-accounts.sql. Don't change unless you
# also change them in the SQL.
HEAD_EMAIL=testcoach@coachify-test.com
HEAD_PASSWORD=TestCoach123!
ASSIST_EMAIL=testassist@coachify-test.com
ASSIST_PASSWORD=TestAssist123!

# Name of the test team created by the seed. Don't change unless you also
# change it in the SQL.
TEAM_NAME=Test Team QA
